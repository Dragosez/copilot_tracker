{
  "name": "copilot-tracker",
  "version": "1.0.0",
  "description": "Ubuntu Topbar Copilot Tracker",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "author": {
    "name": "Dragosez",
    "email": "dragos@example.com"
  },
  "homepage": "https://github.com/Dragosez/copilot-tracker",
  "build": {
    "appId": "com.dragosez.copilot-tracker",
    "productName": "CopilotTracker",
    "linux": {
      "target": ["deb"],
      "category": "Utility",
      "maintainer": "Dragosez <dragos@example.com>",
      "icon": "public/icon.png"
    },
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "puppeteer-core": "^22.6.0",
    "chrome-launcher": "^1.1.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
